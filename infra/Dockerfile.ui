# Meridian J.D. RAG UI: Vite + React + TypeScript single-page app.
# Multi-stage build. Stage 1 builds the static bundle; stage 2 serves it with
# nginx on port 3000 so the full stack (api + ui + db) comes up under
# `docker compose up` with zero keys.
#
# VITE_API_BASE is baked at build time (Vite inlines import.meta.env). For the
# compose stack the browser reaches the API on the host at http://localhost:8000,
# so the default is correct without an override.

FROM node:22-slim AS build
WORKDIR /app
ENV CI=true
COPY ui/package.json ui/package-lock.json ./
RUN npm ci
COPY ui/ ./
ARG VITE_API_BASE=http://localhost:8000
ENV VITE_API_BASE=${VITE_API_BASE}
RUN npm run build

FROM nginx:1.27-alpine AS serve
COPY ui/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 3000

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=5 \
  CMD wget -q -O /dev/null http://localhost:3000/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
