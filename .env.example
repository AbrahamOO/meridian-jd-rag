# Meridian J.D. RAG environment.
#
# The DEFAULT shipped profile is fully zero-key: it runs local embeddings,
# a local reranker, and an abstain-only (or Ollama) generator with NO API keys.
# CI runs MJD_PROFILE=ci (all deterministic mock adapters, also zero-key).
#
# The keys below are OPTIONAL. Set one only if you switch a provider to a cloud
# adapter in config/local.yaml. A cloud adapter constructed without its key
# raises MissingSecretError at construction time (never at call time).

# Selects the config profile: default | ci. Unset means "default".
# MJD_PROFILE=default

# Optional: point the local generator at an Ollama server. If unset, the local
# generator degrades to the abstain-only insufficient-context stub.
# MJD_OLLAMA_URL=http://localhost:11434

# Optional cloud provider keys (only needed for cloud adapters).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
